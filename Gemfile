source "https://rubygems.org"

# GitHub Pages bundles a fixed set of Jekyll plugins and Jekyll itself.
# Using the github-pages gem keeps the local build identical to what
# GitHub Pages renders in production.
gem "github-pages", group: :jekyll_plugins

# Plugins listed in _config.yml under `plugins:` are pulled in here.
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jemoji"
end
